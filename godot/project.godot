; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format is well-documented here:
; https://docs.godotengine.org/en/stable/tutorials/best_practices/project_organization.html

config_version=5

[application]

config/name="Dungeon Delver"
config/description="A Godot 4.x roguelike dungeon crawler demonstrating BSP procedural generation,\nA* pathfinding, signal-driven architecture, and state machines."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.png"

[autoload]

EventBus="*res://scripts/EventBus.gd"
GameManager="*res://scripts/GameManager.gd"
AudioManager="*res://scripts/AudioManager.gd"
SaveSystem="*res://scripts/SaveSystem.gd"

[display]

window/size/viewport_width=900
window/size/viewport_height=600
window/stretch/mode="canvas_items"

